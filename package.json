{
    "name": "auth-service",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "dev": "cross-env NODE_ENV=dev nodemon --exec \"ts-node\" src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "format:fix": "prettier . --write",
        "format:check": "prettier . --check",
        "lint:check": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "jest --no-cache --coverage --all --runInBand",
        "test:watch":"jest --watch --runInBand",
        "prepare": "husky",
        "typeorm": "typeorm-ts-node-commonjs",
        "migration:generate": "npm run typeorm -- migration:generate",
        "migration:run": "npm run typeorm -- migration:run",
        "migration:revert": "npm run typeorm -- migration:revert",
        "schema:sync": "npm run typeorm -- schema:sync",
        "schema:drop": "npm run typeorm -- schema:drop"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-jwt": "^8.5.1",
        "http-errors": "^2.0.1",
        "joi": "^18.1.2",
        "jsonwebtoken": "^9.0.3",
        "jwks-rsa": "^4.0.1",
        "nock": "^13.5.6",
        "pg": "^8.20.0",
        "reflect-metadata": "^0.2.2",
        "rsa-pem-to-jwk": "^1.1.3",
        "ts-node": "^10.9.2",
        "typeorm": "^0.3.28"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.6",
        "@types/http-errors": "^2.0.5",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^14.14.41",
        "@types/supertest": "^7.2.0",
        "@types/winston": "^2.4.4",
        "cross-env": "^10.1.0",
        "eslint": "^10.0.3",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "lint-staged": "^16.4.0",
        "mock-jwks": "^1.0.10",
        "nodemon": "^3.1.14",
        "prettier": "3.8.1",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1"
    },
    "lint-staged": {
        "*.ts": [
            "npm run format:fix",
            "npm run lint:fix"
        ]
    }
}
